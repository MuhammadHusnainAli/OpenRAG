#  Test image: builds the app with dev deps and runs the full test suite ───
# Used by the `test` profile in docker-compose.yml, which provides Postgres /
# RabbitMQ / Qdrant. RUN_INTEGRATION=1 makes pytest collect the integration/ and
# e2e/ suites in addition to the unit tests.
# Embeddings and the LLM are mocked in the tests, so no provider keys are needed.
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/app/src \
    RUN_INTEGRATION=1

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential libmagic1 \
    && rm -rf /var/lib/apt/lists/*

# install deps (incl. dev: pytest, pytest-asyncio, ruff) for layer caching
COPY pyproject.toml ./
COPY src ./src
RUN pip install --upgrade pip && pip install -e ".[dev]"

COPY tests ./tests
COPY db/db.sql ./db.sql

# wait for infra, then run the FULL suite (unit + integration + e2e), failing fast
CMD ["sh", "-c", "python tests/wait_for_services.py && pytest -q --maxfail=1"]
